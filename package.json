{
  "name": "quickprint",
  "version": "0.1.0",
  "private": true,
  "description": "Autonomous print management system for college campus print shops",
  "author": "QuickPrint Team",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "npm --workspace apps/backend run start:dev",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:admin": "npm --workspace apps/admin run dev",
    "dev:desktop": "npm --workspace apps/desktop-app run dev",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run",
    "db:migrate": "npm --workspace apps/backend run prisma:migrate:sqlite",
    "db:generate": "npm --workspace apps/backend run prisma:generate:sqlite",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "package": "npm run rebuild && npm run build && npm run db:generate && electron-builder",
    "rebuild": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "better-sqlite3": "^11.3.0",
    "electron-log": "^5.2.0",
    "electron-store": "^10.0.0",
    "p-queue": "^8.0.1",
    "pdf-to-printer": "^5.6.0",
    "pino": "^9.5.0",
    "socket.io-client": "^4.8.0"
  },
  "main": "apps/desktop-app/dist/main.js",
  "build": {
    "appId": "com.quickprint.software",
    "productName": "QuickPrint",
    "electronVersion": "33.0.1",
    "directories": {
      "output": "dist/installers"
    },
    "files": [
      "cloudflared.exe",
      "apps/desktop-app/dist/**/*",
      "apps/desktop-app/bin/**/*",
      "apps/backend/dist/**/*",
      "apps/backend/prisma/**/*",
      "apps/admin/.next/**/*",
      "apps/admin/public/**/*",
      {
        "from": "apps/admin/.next/static",
        "to": "apps/admin/.next/standalone/apps/admin/.next/static"
      },
      {
        "from": "apps/admin/public",
        "to": "apps/admin/.next/standalone/apps/admin/public"
      },
      "apps/web/.next/**/*",
      "apps/web/public/**/*",
      {
        "from": "apps/web/.next/static",
        "to": "apps/web/.next/standalone/apps/web/.next/static"
      },
      {
        "from": "apps/web/public",
        "to": "apps/web/.next/standalone/apps/web/public"
      },
      "packages/shared/dist/**/*",
      "packages/shared/package.json",
      "node_modules/**/*",
      "node_modules/.prisma/**/*",
      "node_modules/@prisma/engines/**/*",
      "!**/node_modules/*/{test,tests,example,examples,bench,benchmarks}/**/*",
      "!**/*.{ts,tsx,map,md,log}"
    ],
    "asar": true,
    "asarUnpack": [
      "cloudflared.exe",
      "apps/backend",
      "apps/admin",
      "apps/web",
      "packages/shared",
      "apps/backend/prisma/template.db",
      "node_modules/next",
      "node_modules/@prisma",
      "node_modules/@prisma/client",
      "node_modules/@prisma/engines",
      "node_modules/.prisma",
      "node_modules/.bin",
      "**/node_modules/better-sqlite3/**/*",
      "**/node_modules/pdf-to-printer/**/*",
      "apps/desktop-app/bin/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/.prisma/client/query_engine-windows.dll.node",
        "to": "prisma/query_engine-windows.dll.node"
      },
      {
        "from": "node_modules/@prisma/engines/schema-engine-windows.exe",
        "to": "prisma/schema-engine-windows.exe"
      },
      {
        "from": "apps/admin/.next/standalone/node_modules",
        "to": "app.asar.unpacked/apps/admin/.next/standalone/node_modules"
      },
      {
        "from": "apps/web/.next/standalone/node_modules",
        "to": "app.asar.unpacked/apps/web/.next/standalone/node_modules"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "publisherName": "QuickPrint"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "installerIcon": "apps/web/public/favicon.ico",
      "uninstallerIcon": "apps/web/public/favicon.ico"
    }
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "@electron/rebuild": "^4.0.4",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5"
  }
}
