{
  "name": "quickprint",
  "version": "0.1.0",
  "private": true,
  "description": "Autonomous print management system for college campus print shops",
  "author": "QuickPrint Team",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "npm --workspace apps/backend run start:dev",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:admin": "npm --workspace apps/admin run dev",
    "dev:desktop": "npm --workspace apps/print-agent run dev",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run",
    "db:migrate": "npm --workspace apps/backend run prisma:migrate",
    "db:generate": "npm --workspace apps/backend run prisma:generate",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "package": "electron-builder --project apps/desktop-app"
  },
  "main": "apps/desktop-app/dist/main.js",
  "build": {
    "appId": "com.quickprint.software",
    "productName": "QuickPrint",
    "electronVersion": "33.0.1",
    "directories": {
      "output": "dist/installers"
    },
    "files": [
      "apps/desktop-app/dist/**/*",
      "apps/backend/dist/**/*",
      "apps/admin/.next/**/*",
      "apps/web/.next/**/*",
      "packages/shared/dist/**/*",
      "packages/shared/package.json",
      "node_modules/**/*",
      "!**/node_modules/*/{test,tests,example,examples,bench,benchmarks}/**/*",
      "!**/*.{ts,tsx,map,md,log}"
    ],
    "extraResources": [
      {
        "from": "scripts/switch-db.js",
        "to": "scripts/switch-db.js"
      },
      "apps/backend/prisma/schema.prisma",
      "apps/backend/prisma/dev.db"
    ],
    "asar": true,
    "asarUnpack": [
      "apps/backend",
      "apps/admin",
      "apps/web",
      "packages/shared",
      "node_modules/next",
      "node_modules/@prisma/client",
      "node_modules/.bin",
      "**/node_modules/better-sqlite3/**/*",
      "**/node_modules/pdf-to-printer/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "publisherName": "QuickPrint"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "installerIcon": "apps/web/public/favicon.ico",
      "uninstallerIcon": "apps/web/public/favicon.ico"
    }
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "better-sqlite3": "^12.9.0",
    "electron-log": "^5.4.3",
    "electron-store": "^11.0.2",
    "p-queue": "^9.2.0",
    "pdf-to-printer": "^5.8.0",
    "pino": "^10.3.1",
    "socket.io-client": "^4.8.3"
  }
}
